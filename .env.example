# TrendScope configuration
# Copy to .env and set values. On Windows PowerShell, use: $env:VAR="value"

# Keywords (comma-separated)
KEYWORDS="AI, Bitcoin, Climate Change"

# Feature toggles (1=enabled, 0=disabled)
ENABLE_YOUTUBE=1
ENABLE_TWITTER=0
ENABLE_REDDIT=0
ENABLE_WIKIPEDIA=1
ENABLE_HACKERNEWS=1
ENABLE_TMDB=1
ENABLE_COINGECKO=1

# API credentials
YOUTUBE_API_KEY=
TMDB_API_KEY=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="TrendScope/1.0 by user"

# Dev server (uvicorn): uvicorn src.api.main:app --host 127.0.0.1 --port 5000
