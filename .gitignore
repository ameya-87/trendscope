# Ignore virtual environment
venv/
# (Your current repo has a venv/ directory committed-pending; ignore it locally)
(venv/**)


# Ignore Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore data files (raw and processed)
data/raw/*
data/processed/*

# But keep empty folders
!data/raw/.gitkeep
!data/processed/.gitkeep

# Ignore logs
*.log

# Ignore environment configs
.env

# Ignore Power BI cache files
*.pbix
*.pbit
